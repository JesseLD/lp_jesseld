---
import { pageTitle, langAttr, ui, type Locale } from '../data/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---
<!DOCTYPE html>
<html lang={langAttr[locale]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />

  <!-- Fonts: Bricolage Grotesque (display) + DM Sans (body) + Instrument Serif (accent) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

  <!-- Devicons -->
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/assets/css/style.css" />

  <title>{pageTitle[locale]}</title>
</head>
<body>
  <!-- ===== LOADING SCREEN ===== -->
  <div id="loader" class="loader">
    <div class="loader-inner">
      <div class="loader-logo">
        <img src="/assets/img/logo.png" alt="Logo" />
      </div>
      <div class="loader-bar">
        <div class="loader-bar-fill"></div>
      </div>
      <p class="loader-text">{t.loader}</p>
    </div>
  </div>

  <!-- ===== CUSTOM CURSOR ===== -->
  <div id="cursor-dot" class="cursor-dot"></div>
  <div id="cursor-ring" class="cursor-ring"></div>

  <!-- ===== NOISE OVERLAY ===== -->
  <div class="noise-overlay"></div>

  <slot />

  <!-- ===== SCRIPTS ===== -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>
  <script is:inline src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script is:inline src="/assets/js/main.js"></script>
</body>
</html>
